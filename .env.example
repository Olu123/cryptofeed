# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (for Pro memberships)
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...

# App
NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXT_PUBLIC_APP_NAME=CryptoFeed

# RSS Aggregator (used by GitHub Actions)
AGGREGATE_SECRET=your-secret-token-for-cron-endpoint

# CoinGecko (free tier — no key needed, but add for higher limits)
COINGECKO_API_KEY=

# Optional: Resend for transactional emails
RESEND_API_KEY=re_...
